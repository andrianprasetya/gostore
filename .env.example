# Copy to .env (or export) to point GoStore at a real/remote Postgres.
# Leave DATABASE_URL unset to use the embedded Postgres (no Docker needed).
DATABASE_URL=postgres://gostore:gostore@localhost:5432/gostore?sslmode=disable

# Optional: real SMTP for go-notification mail channel (otherwise db+test channels only).
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USERNAME=
# SMTP_PASSWORD=
