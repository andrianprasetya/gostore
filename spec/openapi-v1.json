                      "country": {
                        "type": "string",
                        "example": "ID"
                      },
                      "line1": {
                        "type": "string",
                        "example": "Jl. Sudirman 1"
                      },
                      "postal_code": {
                        "type": "string",
                        "example": "10220"
                      }
                    }
                  }
                },
                "required": [
                  "items"
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
