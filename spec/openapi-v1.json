                        "type": "object",
                        "properties": {
                          "product_id": {
                            "type": "integer",
                            "format": "int64",
                            "example": 1
                          },
                          "quantity": {
                            "type": "integer",
                            "example": 2
                          },
                          "unit_price": {
                            "type": "number",
                            "format": "double",
                            "example": 129.99
                          }
