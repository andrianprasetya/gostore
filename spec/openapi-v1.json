    "/showcase": {
      "get": {
        "tags": [
          "Showcase"
        ],
        "summary": "Edge-type schema showcase",
        "description": "Exercises pointer / time.Time / slice-of-struct / nested / map / no-tag / enum / uuid / []byte.",
        "parameters": [
          {
            "name": "filter",
            "in": "query",
            "description": "Required query param",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Untagged": {
                      "type": "string",
                      "description": "no json tag -\u003e field name used"
                    },
                    "id": {
                      "type": "string",
                      "format": "uuid",
                      "description": "uuid format hint"
                    },
                    "items": {
                      "type": "array",
                      "description": "slice of struct",
                      "items": {
                        "type": "object",
                        "properties": {
                          "product_id": {
                            "type": "integer",
                            "format": "int64",
                            "example": 1
                          },
                          "quantity": {
                            "type": "integer",
                            "example": 2
                          },
                          "unit_price": {
                            "type": "number",
                            "format": "double",
                            "example": 129.99
                          }
                        }
                      }
                    },
                    "meta": {
                      "type": "object",
                      "description": "map -\u003e additionalProperties",
                      "additionalProperties": {
                        "type": "integer"
                      }
                    },
                    "optional": {
                      "type": "string",
