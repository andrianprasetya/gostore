                    },
                    "order_number": {
                      "type": "string",
                      "example": "ORD-2026-0001"
                    },
                    "status": {
                      "type": "string",
                      "description": "pending | paid | shipped | cancelled",
                      "example": "paid"
                    },
                    "total": {
                      "type": "number",
                      "format": "double",
                      "example": 259.98
                    }
                  }
                }
              }
            }
