{
  "openapi": "3.1.0",
  "info": {
    "title": "GoStore API",
    "version": "1.0.0",
    "description": "Dogfooding the **gopackx** stack: migration + audit + notification + docs.",
    "contact": {
      "name": "Andrian Prasetya",
      "url": "https://github.com/andrianprasetya"
    },
    "license": {
      "name": "MIT"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local"
    }
  ],
  "paths": {
    "/admin/orders": {
      "get": {
        "tags": [
          "Admin"
        ],
        "summary": "List all orders (service / API key)",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "created_at": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "id": {
                      "type": "integer",
                      "format": "int64",
                      "example": 1
                    },
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "product_id": {
                            "type": "integer",
                            "format": "int64",
                            "example": 1
                          },
                          "quantity": {
                            "type": "integer",
                            "example": 2
                          },
                          "unit_price": {
                            "type": "number",
                            "format": "double",
                            "example": 129.99
                          }
                        }
                      }
                    },
                    "order_number": {
                      "type": "string",
                      "example": "ORD-2026-0001"
                    },
                    "status": {
                      "type": "string",
                      "description": "pending | paid | shipped | cancelled",
                      "example": "paid"
                    },
                    "total": {
                      "type": "number",
                      "format": "double",
                      "example": 259.98
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 404
                    },
                    "details": {
                      "type": "string"
                    },
                    "error": {
                      "type": "string",
                      "example": "not found"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "apiKeyAuth": []
          }
        ]
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Login with email + password",
        "requestBody": {
          "description": "Credentials",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "andrian@example.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "s3cret-pass"
                  }
                },
                "required": [
                  "email",
                  "password"
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string",
                      "description": "Bearer token for subsequent requests",
                      "example": "42"
                    },
                    "user": {
                      "type": "object",
                      "properties": {
                        "email": {
                          "type": "string",
                          "format": "email"
                        },
                        "id": {
                          "type": "integer",
                          "format": "int64",
                          "example": 42
                        },
                        "name": {
                          "type": "string",
                          "example": "Andrian Prasetya"
                        },
                        "role": {
                          "type": "string",
                          "description": "customer | admin",
                          "example": "customer"
                        },
                        "uuid": {
                          "type": "string",
                          "format": "uuid"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 404
                    },
                    "details": {
                      "type": "string"
                    },
                    "error": {
                      "type": "string",
                      "example": "not found"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": [
