          "description": "Order with line items",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "items": {
                    "type": "array",
                    "description": "Order line items",
                    "items": {
                      "type": "object",
                      "properties": {
                        "product_id": {
                          "type": "integer",
                          "format": "int64",
                          "example": 1
                        },
                        "quantity": {
                          "type": "integer",
                          "example": 2
                        }
                      },
                      "required": [
                        "product_id",
                        "quantity"
                      ]
