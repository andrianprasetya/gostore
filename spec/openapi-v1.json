                          "name": {
                            "type": "string",
                            "example": "Mechanical Keyboard"
                          },
                          "price": {
                            "type": "number",
                            "format": "double",
                            "example": 129.99
                          },
                          "published": {
                            "type": "boolean",
                            "example": true
                          },
                          "sku": {
                            "type": "string",
                            "example": "KB-001"
                          },
                          "stock": {
                            "type": "integer",
                            "format": "int64",
                            "example": 50
                          },
                          "uuid": {
                            "type": "string",
                            "format": "uuid"
                          }
                        }
                      }
                    },
                    "total": {
                      "type": "integer",
                      "format": "int64",
                      "example": 42
                    }
                  }
                }
              }
            }
          }
        }
      },
