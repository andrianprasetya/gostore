              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string",
                      "description": "Bearer token for subsequent requests",
                      "example": "42"
                    },
                    "user": {
                      "type": "object",
                      "properties": {
                        "email": {
                          "type": "string",
                          "format": "email"
                        },
                        "id": {
                          "type": "integer",
                          "format": "int64",
                          "example": 42
                        },
                        "name": {
                          "type": "string",
                          "example": "Andrian Prasetya"
                        },
                        "role": {
                          "type": "string",
                          "description": "customer | admin",
                          "example": "customer"
                        },
                        "uuid": {
                          "type": "string",
                          "format": "uuid"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 404
                    },
                    "details": {
                      "type": "string"
                    },
                    "error": {
                      "type": "string",
                      "example": "not found"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/notifications": {
