    "/products": {
      "get": {
        "tags": [
          "Products"
        ],
        "summary": "List published products",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Page size (default 20)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Page offset (default 0)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "all",
            "in": "query",
            "description": "Include unpublished (true/false)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Request-ID",
            "in": "header",
            "description": "Optional client trace id",
            "schema": {
              "type": "string"
            }
