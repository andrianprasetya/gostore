{
  "openapi": "3.1.0",
  "info": {
    "title": "GoStore API",
    "version": "2.0.0"
  },
  "paths": {
    "/admin/orders": {
      "get": {
        "tags": [
          "Admin"
        ],
        "summary": "List all orders (service / API key)",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "created_at": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "id": {
                      "type": "integer",
                      "format": "int64",
                      "example": 1
                    },
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "product_id": {
                            "type": "integer",
                            "format": "int64",
                            "example": 1
                          },
                          "quantity": {
                            "type": "integer",
                            "example": 2
                          },
                          "unit_price": {
                            "type": "number",
                            "format": "double",
                            "example": 129.99
                          }
                        }
                      }
                    },
                    "order_number": {
                      "type": "string",
                      "example": "ORD-2026-0001"
                    },
                    "status": {
                      "type": "string",
                      "description": "pending | paid | shipped | cancelled",
                      "example": "paid"
                    },
                    "total": {
                      "type": "number",
                      "format": "double",
                      "example": 259.98
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 404
                    },
                    "details": {
                      "type": "string"
                    },
                    "error": {
                      "type": "string",
                      "example": "not found"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "apiKeyAuth": []
          }
        ]
      }
    },
    "/audit/transactions/{txid}": {
      "get": {
        "tags": [
          "Audit"
        ],
        "summary": "Correlated audit trail for one transaction",
        "description": "Returns every data-change and third-party API-call that shared one request's transaction id.",
        "parameters": [
          {
            "name": "txid",
            "in": "path",
            "description": "Transaction id (from X-Transaction-ID)",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "api_calls": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "created_at": {
                            "type": "string",
                            "format": "date-time"
                          },
                          "duration_ms": {
                            "type": "integer",
                            "example": 6
                          },
                          "endpoint": {
                            "type": "string",
                            "example": "/v1/charges"
                          },
                          "id": {
                            "type": "integer",
                            "format": "int64"
                          },
                          "method": {
                            "type": "string",
                            "example": "POST"
                          },
                          "service": {
                            "type": "string",
                            "example": "payment-gateway"
                          },
                          "status_code": {
                            "type": "integer",
                            "example": 200
                          }
                        }
                      }
                    },
                    "data_changes": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "action": {
                            "type": "string",
                            "description": "create|update|delete|soft_delete|restore",
                            "example": "create"
                          },
                          "created_at": {
                            "type": "string",
                            "format": "date-time"
                          },
                          "entity_id": {
                            "type": "string",
                            "example": "12"
                          },
                          "entity_type": {
                            "type": "string",
                            "example": "orders"
                          },
                          "id": {
                            "type": "integer",
                            "format": "int64"
                          },
                          "new_values": {
                            "type": "object",
                            "additionalProperties": {}
                          },
                          "old_values": {
                            "type": "object",
                            "additionalProperties": {}
                          },
                          "user_id": {
                            "type": "string",
                            "example": "42"
                          }
                        }
                      }
                    },
                    "summary": {
                      "type": "object",
                      "description": "counts per kind",
                      "additionalProperties": {
                        "type": "integer"
                      }
                    },
                    "transaction_id": {
                      "type": "string",
                      "example": "20260603T050002-..."
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 404
                    },
                    "details": {
                      "type": "string"
                    },
                    "error": {
                      "type": "string",
                      "example": "not found"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "apiKeyAuth": []
          }
        ]
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Login with email + password",
        "requestBody": {
          "description": "Credentials",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "andrian@example.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "s3cret-pass"
                  }
                },
                "required": [
                  "email",
                  "password"
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string",
                      "description": "Bearer token for subsequent requests",
                      "example": "42"
                    },
                    "user": {
                      "type": "object",
                      "properties": {
                        "email": {
                          "type": "string",
                          "format": "email"
                        },
                        "id": {
                          "type": "integer",
                          "format": "int64",
                          "example": 42
                        },
                        "name": {
                          "type": "string",
                          "example": "Andrian Prasetya"
                        },
                        "role": {
                          "type": "string",
                          "description": "customer | admin",
                          "example": "customer"
                        },
                        "uuid": {
                          "type": "string",
                          "format": "uuid"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 404
                    },
                    "details": {
                      "type": "string"
                    },
                    "error": {
                      "type": "string",
                      "example": "not found"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Register a new customer",
