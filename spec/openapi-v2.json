          "description": "Registration payload",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "andrian@example.com"
                  },
                  "name": {
                    "type": "string",
                    "description": "Full name",
                    "example": "Andrian Prasetya"
                  },
                  "password": {
                    "type": "string",
                    "description": "Min 6 chars",
                    "example": "s3cret-pass"
